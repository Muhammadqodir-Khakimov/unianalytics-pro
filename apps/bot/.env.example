# Telegram bot token — @BotFather dan oling
TELEGRAM_BOT_TOKEN=1234567890:ABC-your-bot-token-here

# Backend API base URL — bot HTTP orqali backendga qaraydi
BACKEND_API_URL=http://backend:8000/api/v1

# Redis — FSM storage va auth tokenlari uchun
REDIS_URL=redis://redis:6379/2

# Webhook URL (production uchun) — bo'sh qoldirsa polling rejimi ishlatiladi
# WEBHOOK_URL=https://example.com/bot
# WEBHOOK_SECRET=secret-here
# WEBAPP_HOST=0.0.0.0
# WEBAPP_PORT=8080

# Throttling
RATE_LIMIT_PER_MIN=20

# Bot rejimi: polling | webhook
BOT_MODE=polling
