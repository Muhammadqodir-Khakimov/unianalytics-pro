# PRODUCTION uchun .env namuna fayl
# Faqat namuna — real production da SECRET_KEY va parollarni o'zgartiring!

# OLTP Database
OLTP_DB_HOST=postgres-oltp
OLTP_DB_PORT=5432
OLTP_DB_USER=oltp_admin
OLTP_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
OLTP_DB_NAME=student_oltp_prod

# OLAP Database
OLAP_DB_HOST=postgres-olap
OLAP_DB_PORT=5432
OLAP_DB_USER=olap_admin
OLAP_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
OLAP_DB_NAME=student_olap_prod

# Redis (with password)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0
CELERY_BROKER_URL=redis://:CHANGE_ME@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@redis:6379/1

# Application
APP_NAME=Student Rating OLAP
APP_ENV=production
APP_DEBUG=false
APP_PORT=8000

# Security — MUST BE A STRONG 64+ CHARACTER RANDOM STRING
SECRET_KEY=GENERATE_A_STRONG_RANDOM_KEY_USING_PYTHON_SECRETS_TOKEN_URLSAFE_64
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — your real domain
CORS_ORIGINS=https://yourdomain.uz,https://www.yourdomain.uz

# Email (Gmail SMTP namuna)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASSWORD=YOUR_APP_PASSWORD
SMTP_FROM=noreply@yourdomain.uz

# Telegram bot (optional)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER

# Sentry (optional but recommended)
SENTRY_DSN=https://your-key@sentry.io/your-project

# Flower auth
FLOWER_USER=flower_admin
FLOWER_PASS=CHANGE_ME
