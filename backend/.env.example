# OLTP Database
OLTP_DB_HOST=postgres-oltp
OLTP_DB_PORT=5432
OLTP_DB_USER=oltp_user
OLTP_DB_PASSWORD=oltp_pass
OLTP_DB_NAME=student_oltp

# OLAP Database
OLAP_DB_HOST=postgres-olap
OLAP_DB_PORT=5432
OLAP_DB_USER=olap_user
OLAP_DB_PASSWORD=olap_pass
OLAP_DB_NAME=student_olap

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Application
APP_NAME=Student Rating OLAP System
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# Security
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
